#!/bin/zsh

# ── Project Settings ──────────────────────────────
KEYCHAIN_ENTRY=""
ENV_URL_KEY=""
# ─────────────────────────────────────────────────

# Load non-sensitive config from .env
export WP_URL=$(grep $ENV_URL_KEY .env | cut -d '=' -f2)

# Pull from Keychain
export WP_USERNAME=$(security find-generic-password -s "$KEYCHAIN_ENTRY" -g 2>&1 | grep "acct" | cut -d '"' -f4)
export WP_APP_PASSWORD=$(security find-generic-password -s "$KEYCHAIN_ENTRY" -w)

# Write temporary netrc
WP_DOMAIN=$(echo $WP_URL | sed 's|https://||' | sed 's|http://||')
echo "machine $WP_DOMAIN login $WP_USERNAME password $WP_APP_PASSWORD" > ~/.netrc
chmod 600 ~/.netrc

# Delete netrc when terminal closes
trap "rm -f ~/.netrc" EXIT

# Remove secrets from environment
unset WP_APP_PASSWORD
unset WP_USERNAME

echo "✓ Secrets loaded"